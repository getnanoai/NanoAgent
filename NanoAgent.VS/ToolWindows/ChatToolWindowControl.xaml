<UserControl x:Class="NanoAgent.VS.ToolWindows.ChatToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NanoAgent.VS.ToolWindows"
             Background="#FF1E1E1E"
             Foreground="#FFCCCCCC"
             FontFamily="Segoe UI"
             FontSize="13"
             TextElement.Foreground="#FFCCCCCC">
    <UserControl.Resources>
        <!-- 1. Segment code template -->
        <DataTemplate x:Key="SegmentCodeTemplate">
            <Border Background="#FF2D2D30" BorderBrush="#FF3C3C3C"
                    BorderThickness="1" Padding="10,6" CornerRadius="4" Margin="0,2,0,4">
                <TextBlock Text="{Binding Text}" FontFamily="Consolas"
                           Foreground="#FFD4D4D4" TextWrapping="Wrap"
                           FontSize="12" LineHeight="18" />
            </Border>
        </DataTemplate>

        <!-- 2. Segment plain text template -->
        <DataTemplate x:Key="SegmentTextTemplate">
            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                       Foreground="#FFCCCCCC" LineHeight="20"
                       Margin="0,0,0,2" />
        </DataTemplate>

        <!-- 3. Segment template selector -->
        <local:SegmentTemplateSelector x:Key="SegmentTemplateSelector"
            CodeTemplate="{StaticResource SegmentCodeTemplate}"
            TextTemplate="{StaticResource SegmentTextTemplate}" />

        <!-- 4. Message text to segment list converter -->
        <local:MessageToSegmentsConverter x:Key="MessageToSegments" />
        <local:WidthFractionConverter x:Key="WidthFractionConverter" />

        <!-- 5. DataTemplate for UserMessage -->
        <DataTemplate DataType="{x:Type local:UserMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.86}"
                    HorizontalAlignment="Right"
                    Background="#FF2D2D30" BorderBrush="#FF3C3C3C"
                    BorderThickness="1" CornerRadius="8" Padding="10,8"
                    Margin="0,0,0,8">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           Foreground="#FFCCCCCC" LineHeight="20" />
            </Border>
        </DataTemplate>

        <!-- 6. DataTemplate for AssistantMessage (with code block support) -->
        <DataTemplate DataType="{x:Type local:AssistantMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.94}"
                    HorizontalAlignment="Left"
                    Background="Transparent" Padding="0,0,0,8">
                <ItemsControl ItemsSource="{Binding Text, Converter={StaticResource MessageToSegments}}"
                              Focusable="False"
                              ItemTemplateSelector="{StaticResource SegmentTemplateSelector}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <!-- 7. DataTemplate for ReasoningMessage -->
        <DataTemplate DataType="{x:Type local:ReasoningMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.94}"
                    HorizontalAlignment="Left"
                    Background="Transparent" Padding="0,0,0,4">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           Foreground="#FF8F8F8F" FontStyle="Italic"
                           LineHeight="18" FontSize="12" />
            </Border>
        </DataTemplate>

        <!-- 8. DataTemplate for ToolMessage -->
        <DataTemplate DataType="{x:Type local:ToolMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.94}"
                    HorizontalAlignment="Left"
                    BorderBrush="#FFCCA700" BorderThickness="2,0,0,0"
                    Background="#FF252526" CornerRadius="0,4,4,0"
                    Padding="10,6" Margin="0,0,0,4">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           Foreground="#FF8F8F8F" FontFamily="Consolas"
                           FontSize="12" LineHeight="18" />
            </Border>
        </DataTemplate>

        <!-- 9. DataTemplate for SystemMessage -->
        <DataTemplate DataType="{x:Type local:SystemMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Center"
                    BorderBrush="#55CCA700" BorderThickness="1"
                    Background="#1ACCA700" CornerRadius="8"
                    Padding="8,6" Margin="0,0,0,6">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           Foreground="#FFCCA700" FontSize="12"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <!-- 10. DataTemplate for ToolCallStatusMessage -->
        <DataTemplate DataType="{x:Type local:ToolCallStatusMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.94}"
                    HorizontalAlignment="Left"
                    BorderBrush="#FF3C3C3C" BorderThickness="1"
                    CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                    Background="#FF252526">
                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"
                           Foreground="#FFCCCCCC" FontSize="12"
                           FontFamily="Consolas" LineHeight="18" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5"
                BorderBrush="#FF3C3C3C" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="3" Padding="8,2" Background="#FF0E639C" Margin="0,0,8,0">
                    <TextBlock x:Name="StatusText" Text="Starting..." Foreground="White"
                               FontSize="11" FontFamily="Consolas" />
                </Border>
                <TextBlock Grid.Column="1" x:Name="ModelText" Text="" Foreground="#FF8F8F8F"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="3" x:Name="ProfileText" Text="" Foreground="#FF8F8F8F"
                           FontSize="11" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="MessagesScrollViewer"
                      Background="Transparent"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      Padding="14,10,14,4"
                      PanningMode="VerticalOnly">
            <Grid>
                <!-- Empty state -->
                <TextBlock x:Name="EmptyStateText"
                           Text="Welcome to NanoAgent for Visual Studio.&#x0a;&#x0a;Start typing a message or use / commands."
                           Foreground="#FF8F8F8F" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="420" LineHeight="22" />

                <!-- Message list -->
                <ItemsControl x:Name="MessagesList" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#FF252526" Padding="10,6,10,10"
                BorderBrush="#FF3C3C3C" BorderThickness="0,1,0,0">
            <Border BorderBrush="#FF3C3C3C" BorderThickness="1" CornerRadius="8"
                    Background="#FF1E1E1E">
                <Grid Margin="8,4,8,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="InputTextBox"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             MinHeight="28" MaxHeight="100"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#FFCCCCCC"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             CaretBrush="#FFCCCCCC"
                             VerticalContentAlignment="Center"
                             KeyDown="OnInputKeyDown" />
                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="3" x:Name="SendButton"
                                Content="Send"
                                MinWidth="60" MinHeight="26"
                                Margin="6,0,0,0"
                                Padding="14,0"
                                Background="#FF0E639C"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Click="OnSendClick" />
                        <Button Grid.Column="2" x:Name="CancelButton"
                                Content="Stop"
                                MinWidth="50" MinHeight="26"
                                Margin="0,0,6,0"
                                Padding="8,0"
                                Background="#33F48771"
                                Foreground="#FFF48771"
                                BorderThickness="1"
                                BorderBrush="#66F48771"
                                FontSize="12"
                                Visibility="Collapsed"
                                Click="OnCancelClick" />
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <!-- Modal Overlay for permission/text requests -->
        <Border Grid.RowSpan="3" x:Name="ModalOverlay" Visibility="Collapsed"
                Background="#88000000" Panel.ZIndex="100">
            <Border MaxWidth="520" MaxHeight="520"
                    Background="#FF252526" BorderBrush="#FF3C3C3C"
                    BorderThickness="1" CornerRadius="8" Padding="18"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="ModalTitle"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#FFCCCCCC" Text="" />
                    <TextBlock Grid.Row="1" x:Name="ModalDescription"
                               FontSize="12" Foreground="#FF8F8F8F"
                               Margin="0,8,0,12" TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2" x:Name="ModalBodyScroll"
                                  VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <StackPanel x:Name="ModalBodyPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="3" x:Name="ModalActionsPanel"
                                Orientation="Horizontal" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
