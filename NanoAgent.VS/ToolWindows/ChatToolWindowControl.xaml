<UserControl x:Class="NanoAgent.VS.ToolWindows.ChatToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NanoAgent.VS.ToolWindows"
             Background="#FF1E1E1E"
             Foreground="#FFCCCCCC"
             FontFamily="Segoe UI"
             FontSize="13"
             TextElement.Foreground="#FFCCCCCC">
    <UserControl.Resources>
        <local:WidthFractionConverter x:Key="WidthFractionConverter" />

        <!-- Toolbar icon-button style -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFCCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#FF3C3C3C" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2D2D30" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- UserMessage -->
        <DataTemplate DataType="{x:Type local:UserMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.86}"
                    HorizontalAlignment="Right"
                    Background="#FF2D2D30" BorderBrush="#FF3C3C3C"
                    BorderThickness="1" CornerRadius="8" Padding="10,6"
                    Margin="0,0,0,8">
                <local:MarkdownPresenter Markdown="{Binding Text}" />
            </Border>
        </DataTemplate>

        <!-- AssistantMessage -->
        <DataTemplate DataType="{x:Type local:AssistantMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Left"
                    Background="Transparent" Padding="0,0,0,8">
                <local:MarkdownPresenter Markdown="{Binding Text}" />
            </Border>
        </DataTemplate>

        <!-- ReasoningMessage (collapsible) -->
        <DataTemplate DataType="{x:Type local:ReasoningMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Left" Padding="0,0,0,6">
                <Expander Header="{Binding Summary}" Foreground="#FF8F8F8F" FontSize="12">
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                               local:SelectableTextBlock.IsEnabled="True"
                               Foreground="#FF8F8F8F" FontStyle="Italic"
                               LineHeight="18" FontSize="12" Margin="6,4,0,0" />
                </Expander>
            </Border>
        </DataTemplate>

        <!-- ToolMessage (plain) -->
        <DataTemplate DataType="{x:Type local:ToolMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Left"
                    BorderBrush="#FFCCA700" BorderThickness="2,0,0,0"
                    Background="#FF252526" CornerRadius="0,4,4,0"
                    Padding="10,6" Margin="0,0,0,4">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           local:SelectableTextBlock.IsEnabled="True"
                           Foreground="#FF8F8F8F" FontFamily="Consolas"
                           FontSize="12" LineHeight="18" />
            </Border>
        </DataTemplate>

        <!-- SystemMessage -->
        <DataTemplate DataType="{x:Type local:SystemMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Center"
                    BorderBrush="#55CCA700" BorderThickness="1"
                    Background="#1ACCA700" CornerRadius="8"
                    Padding="8,6" Margin="0,0,0,6">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           local:SelectableTextBlock.IsEnabled="True"
                           Foreground="#FFCCA700" FontSize="12"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <!-- ToolCallStatusMessage (collapsible card with diff/output) -->
        <DataTemplate DataType="{x:Type local:ToolCallStatusMessage}">
            <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource WidthFractionConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Left"
                    BorderBrush="#FF3C3C3C" BorderThickness="1"
                    CornerRadius="6" Padding="8,4" Margin="0,0,0,6"
                    Background="#FF252526">
                <Expander IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding HeaderText}" Foreground="#FFCCCCCC"
                                       local:SelectableTextBlock.IsEnabled="True"
                                       FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MetaText}" Foreground="#FF8F8F8F"
                                       local:SelectableTextBlock.IsEnabled="True"
                                       FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <local:ToolCallContentPresenter Message="{Binding}" Margin="0,4,0,0" />
                </Expander>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5"
                BorderBrush="#FF3C3C3C" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="3" Padding="8,2" Background="#FF0E639C" Margin="0,0,8,0">
                    <TextBlock x:Name="StatusText" Text="Starting..." Foreground="White"
                               local:SelectableTextBlock.IsEnabled="True"
                               FontSize="11" FontFamily="Consolas" />
                </Border>
                <TextBlock Grid.Column="1" x:Name="ModelText" Text="" Foreground="#FF8F8F8F"
                           local:SelectableTextBlock.IsEnabled="True"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                           TextTrimming="CharacterEllipsis" MaxWidth="220" />
                <TextBlock Grid.Column="3" x:Name="ContextText" Text="" Foreground="#FF8F8F8F"
                           local:SelectableTextBlock.IsEnabled="True"
                           FontSize="11" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="MessagesScrollViewer"
                      Background="Transparent"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      Padding="14,10,14,4"
                      PanningMode="VerticalOnly">
            <Grid>
                <TextBlock x:Name="EmptyStateText"
                           Text="Welcome to NanoAgent for Visual Studio.&#x0a;&#x0a;Start typing a message or use / commands. Try the editor context menu to send a selection, review a file, or review the git diff."
                           Foreground="#FF8F8F8F" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="460" LineHeight="22" />

                <ItemsControl x:Name="MessagesList" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#FF252526" Padding="10,6,10,10"
                BorderBrush="#FF3C3C3C" BorderThickness="0,1,0,0">
            <StackPanel>
                <!-- Prompt queue: messages typed while a turn is running, drained in order. -->
                <ItemsControl x:Name="PromptQueueList" Margin="0,0,0,6" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF1E1E1E" BorderBrush="#FF0E639C" BorderThickness="2,1,1,1"
                                    CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#FF8F8F8F"
                                               FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="&#x00D7;" Tag="{Binding}"
                                            Width="18" Height="18" Margin="6,0,0,0"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#FF8F8F8F" Cursor="Hand"
                                            ToolTip="Remove from queue" Click="OnRemoveQueuedClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Composer toolbar -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button x:Name="NewChatButton" Style="{StaticResource ToolbarButton}"
                            Content="＋ New" ToolTip="Start a new chat session" Click="OnNewChatClick" />
                    <Button x:Name="SessionsButton" Style="{StaticResource ToolbarButton}"
                            Content="Sessions" ToolTip="Browse saved sessions" Click="OnSessionsClick" />
                    <Button x:Name="ModelButton" Style="{StaticResource ToolbarButton}"
                            Content="Model" ToolTip="Pick model / reasoning / thinking" Click="OnModelClick" />
                    <Button x:Name="AddContextButton" Style="{StaticResource ToolbarButton}"
                            Content="@ Context" ToolTip="Reference a file (/read)" Click="OnAddContextClick" />
                    <Button x:Name="SettingsButton" Style="{StaticResource ToolbarButton}"
                            Content="Settings" ToolTip="Settings" Click="OnSettingsClick" />
                    <TextBlock x:Name="MetricsText" Text="" Foreground="#FF8F8F8F" FontSize="10"
                               local:SelectableTextBlock.IsEnabled="True"
                               VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>

                <Border BorderBrush="#FF3C3C3C" BorderThickness="1" CornerRadius="8"
                        Background="#FF1E1E1E">
                    <Grid Margin="8,4,8,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" x:Name="InputTextBox"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="28" MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#FFCCCCCC"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 CaretBrush="#FFCCCCCC"
                                 VerticalContentAlignment="Center"
                                 PreviewKeyDown="OnInputKeyDown" />
                        <Grid Grid.Row="1" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- one button — arrow to send, square to stop. -->
                            <Button Grid.Column="1" x:Name="SendButton"
                                    Content="&#x2191;"
                                    Width="28" Height="28"
                                    Background="#FF0E639C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="Bold"
                                    FontSize="15"
                                    Cursor="Hand"
                                    Click="OnSendClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14" />
                                            <!-- white-tint overlay so hover/press read on top of the dynamic blue/red background. -->
                                            <Border x:Name="Overlay" CornerRadius="14" Background="White" Opacity="0" />
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Overlay" Property="Opacity" Value="0.15" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Overlay" Property="Opacity" Value="0.3" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Slash-command / mention autocomplete -->
        <Popup x:Name="SuggestionPopup" Placement="Top" PlacementTarget="{Binding ElementName=InputTextBox}"
               AllowsTransparency="True" StaysOpen="False" IsOpen="False"
               MaxHeight="240" Width="{Binding ElementName=InputTextBox, Path=ActualWidth}">
            <Border Background="#FF252526" BorderBrush="#FF3C3C3C" BorderThickness="1" CornerRadius="6">
                <ListBox x:Name="SuggestionList" Background="Transparent" BorderThickness="0"
                         Foreground="#FFCCCCCC" MaxHeight="238"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseLeftButtonUp="OnSuggestionClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Command}" FontFamily="Consolas"
                                               Foreground="#FF4DAAFC" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Usage}" Foreground="#FF8F8F8F"
                                               FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" Foreground="#FF8F8F8F"
                                           FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>

        <!-- Modal Overlay for permission/text/model/session requests -->
        <Border Grid.RowSpan="3" x:Name="ModalOverlay" Visibility="Collapsed"
                Background="#88000000" Panel.ZIndex="100">
            <Border MaxWidth="560" MaxHeight="560"
                    Background="#FF252526" BorderBrush="#FF3C3C3C"
                    BorderThickness="1" CornerRadius="8" Padding="18"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="ModalTitle"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#FFCCCCCC" Text="" />
                    <TextBlock Grid.Row="1" x:Name="ModalDescription"
                               FontSize="12" Foreground="#FF8F8F8F"
                               Margin="0,8,0,12" TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2" x:Name="ModalBodyScroll"
                                  VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" MinWidth="360">
                        <StackPanel x:Name="ModalBodyPanel" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="3" x:Name="ModalActionsPanel"
                                Orientation="Horizontal" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
