{
  "name": "nanoagent",
  "displayName": "NanoAgent",
  "description": "Use NanoAgent inside VS Code through ACP mode.",
  "version": "0.0.1",
  "icon": "resources/logo.png",
  "license": "Apache-2.0",
  "homepage": "https://github.com/rizwan3d/NanoAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rizwan3d/NanoAgent.git",
    "directory": "NanoAgent.VsCode"
  },
  "bugs": {
    "url": "https://github.com/rizwan3d/NanoAgent/issues"
  },
  "keywords": [
    "nanoagent",
    "ai",
    "coding-agent",
    "acp",
    "agent-client-protocol"
  ],
  "files": [
    "dist/**",
    "resources/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "publisher": "rizwan3d",
  "galleryBanner": {
    "color": "#101820",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:nanoagent.openChat",
    "onCommand:nanoagent.showTerminals",
    "onView:nanoagent.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "nanoagent",
          "title": "NanoAgent",
          "icon": "resources/logo.png"
        }
      ]
    },
    "views": {
      "nanoagent": [
        {
          "type": "webview",
          "id": "nanoagent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "nanoagent.start",
        "title": "NanoAgent: Start"
      },
      {
        "command": "nanoagent.stop",
        "title": "NanoAgent: Stop"
      },
      {
        "command": "nanoagent.restart",
        "title": "NanoAgent: Restart"
      },
      {
        "command": "nanoagent.openChat",
        "title": "NanoAgent: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "nanoagent.newChat",
        "title": "NanoAgent: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "nanoagent.sendSelection",
        "title": "NanoAgent: Send Selection"
      },
      {
        "command": "nanoagent.sendCurrentFile",
        "title": "NanoAgent: Send Current File"
      },
      {
        "command": "nanoagent.reviewCurrentFile",
        "title": "NanoAgent: Review Current File"
      },
      {
        "command": "nanoagent.reviewGitDiff",
        "title": "NanoAgent: Review Git Diff"
      },
      {
        "command": "nanoagent.explainSelection",
        "title": "NanoAgent: Explain Selection"
      },
      {
        "command": "nanoagent.planChanges",
        "title": "NanoAgent: Plan Changes"
      },
      {
        "command": "nanoagent.applySuggestedChanges",
        "title": "NanoAgent: Apply Suggested Changes"
      },
      {
        "command": "nanoagent.showTerminals",
        "title": "NanoAgent: Show Background Terminals",
        "icon": "$(terminal)"
      },
      {
        "command": "nanoagent.openLogs",
        "title": "NanoAgent: Open Logs"
      },
      {
        "command": "nanoagent.openSettings",
        "title": "NanoAgent: Open Settings"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "nanoagent.openChat",
          "group": "navigation@90"
        }
      ],
      "view/title": [
        {
          "command": "nanoagent.newChat",
          "when": "view == nanoagent.chatView",
          "group": "navigation@1"
        },
        {
          "command": "nanoagent.start",
          "when": "view == nanoagent.chatView",
          "group": "navigation@2"
        },
        {
          "command": "nanoagent.showTerminals",
          "when": "view == nanoagent.chatView",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "NanoAgent",
      "properties": {
        "nanoagent.command": {
          "type": "string",
          "default": "nanoai",
          "description": "The command to run NanoAgent CLI."
        },
        "nanoagent.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--acp"
          ],
          "description": "Arguments to pass to the NanoAgent CLI."
        },
        "nanoagent.workingDirectory": {
          "type": "string",
          "description": "The working directory for the NanoAgent CLI. Defaults to workspace root."
        },
        "nanoagent.acpAuthenticationToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional ACP authentication token. Used when the ACP server returns `authMethods: [\"token\"]`. The extension checks VS Code SecretStorage key `nanoagent.acpAuthToken` first, then this setting, then environment variable `NANOAGENT_ACP_AUTH_TOKEN`."
        },
        "nanoagent.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Whether to start NanoAgent automatically when VS Code starts."
        },
        "nanoagent.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "The log level for the extension."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package:vsix": "vsce package --no-dependencies --githubBranch master",
    "publish:marketplace": "vsce publish --no-dependencies --githubBranch master"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  }
}
