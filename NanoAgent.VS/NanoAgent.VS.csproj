<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RuntimeIdentifiers>win</RuntimeIdentifiers>
    <BuildNanoAgentCliProject Condition="'$(BuildNanoAgentCliProject)' == ''">true</BuildNanoAgentCliProject>
    <NanoAgentCliProjectPath>..\NanoAgent.CLI\NanoAgent.CLI.csproj</NanoAgentCliProjectPath>
    <NanoAgentCliOutputDir>..\NanoAgent.CLI\bin\$(Configuration)\net10.0\</NanoAgentCliOutputDir>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <ProjectGuid>{E3FFC521-F526-4E30-BB05-1F08925B0266}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>NanoAgent.VS</RootNamespace>
    <AssemblyName>NanoAgent.VS</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>true</CopyOutputSymbolsToOutputDirectory>
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Properties\IsExternalInit.cs" />
    <Compile Include="NanoAgent.VSPackage.cs" />
    <Compile Include="Services\LogService.cs" />
    <Compile Include="Services\NanoAgentProcessManager.cs" />
    <Compile Include="Services\VsAgentService.cs" />
    <Compile Include="Services\VsProtocol.cs" />
    <Compile Include="ToolWindows\ChatToolWindow.cs" />
    <Compile Include="ToolWindows\ChatToolWindowControl.cs" />
    <Compile Include="ToolWindows\ChatMessageModel.cs" />
  </ItemGroup>
  <ItemGroup>
    <Page Include="ToolWindows\ChatToolWindowControl.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <VSCTCompile Include="NanoAgentVSPackage.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="VSPackage.resx">
      <MergeWithCTO>true</MergeWithCTO>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <Content Include="Resources\logo.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="..\LICENSE.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Runtime" />
    <Reference Include="System.Threading.Tasks" />
    <Reference Include="System.Design" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="System.Xaml" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.0.32112.339" ExcludeAssets="runtime" NoWarn="NU1604" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.14.2120" NoWarn="NU1604" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
    <PackageReference Include="Microsoft.VisualStudio.Shell.Framework" Version="17.0.32112.339" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VisualStudio.Shell.Interop" Version="17.0.32112.339" ExcludeAssets="runtime" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Target Name="BuildNanoAgentCliPayload" BeforeTargets="GetVsixSourceItems" Condition="Exists('$(NanoAgentCliProjectPath)')">
    <Exec Condition="'$(BuildNanoAgentCliProject)' == 'true'"
          Command="dotnet build &quot;$(NanoAgentCliProjectPath)&quot; --configuration &quot;$(Configuration)&quot; --nologo" />
    <Error Condition="!Exists('$(NanoAgentCliOutputDir)NanoAgent.CLI.exe') and !Exists('$(NanoAgentCliOutputDir)NanoAgent.CLI.dll')"
           Text="NanoAgent CLI payload was not found in '$(NanoAgentCliOutputDir)'. Build NanoAgent.CLI first or set BuildNanoAgentCliProject=true." />
    <ItemGroup>
      <NanoAgentCliRootPayload Include="$(NanoAgentCliOutputDir)*.exe;$(NanoAgentCliOutputDir)*.dll;$(NanoAgentCliOutputDir)*.json" Exclude="$(NanoAgentCliOutputDir)**\*.pdb" />
      <NanoAgentCliRuntimePayload Include="$(NanoAgentCliOutputDir)runtimes\**\*" Exclude="$(NanoAgentCliOutputDir)**\*.pdb" />
      <Content Include="@(NanoAgentCliRootPayload)">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <IncludeInVSIX>true</IncludeInVSIX>
        <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
        <Visible>false</Visible>
      </Content>
      <Content Include="@(NanoAgentCliRuntimePayload)">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <IncludeInVSIX>true</IncludeInVSIX>
        <Link>runtimes\%(RecursiveDir)%(Filename)%(Extension)</Link>
        <Visible>false</Visible>
      </Content>
    </ItemGroup>
    <Copy SourceFiles="@(NanoAgentCliRootPayload)"
          DestinationFiles="@(NanoAgentCliRootPayload->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(NanoAgentCliRuntimePayload)"
          DestinationFiles="@(NanoAgentCliRuntimePayload->'$(OutDir)runtimes\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != ''" />
</Project>
